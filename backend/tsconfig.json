{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "lib":             ["ES2020"],
    "outDir":          "./dist",
    "rootDir":         "./src",
    "strict":          true,
    "esModuleInterop": true,
    "skipLibCheck":    true,
    "resolveJsonModule": true,
    "baseUrl":         ".",
    "paths": {
      "@config/*":     ["src/config/*"],
      "@middleware/*": ["src/middleware/*"],
      "@modules/*":    ["src/modules/*"],
      "@types/*":      ["src/types/*"],
      "@utils/*":      ["src/utils/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
