# ============================================================
# advisory-platform — variables de entorno
# Copia este archivo a .env y completa los valores
# NUNCA commitees .env al repositorio
# ============================================================

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=advisory_platform

# JWT
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_largo_aleatorio
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_diferente
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Servidor
PORT=3000
NODE_ENV=development

# CORS — frontend Angular en desarrollo
CORS_ORIGIN=http://localhost:4200

# Daily.co — video (dejar vacío hasta Sprint 3)
DAILY_API_KEY=
DAILY_API_URL=https://api.daily.co/v1

# Archivos (dejar vacío hasta que se implemente)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
